  "actions": [
    {
      "time": 4.436374,
      "action_type": "StayStill",
      "movement_state": "StayStill",
      "dialog_text": "Hey Ethan, Jason, Frank, are you guys coming to the environmental club meeting this Friday? We need more voices to push for recycling initiatives.",
      "plan": "I want to start a conversation about the environmental club meeting later this week. Maybe I can get some support from the others here.",
      "target_location": null
    },
    {
      "time": 13.7300444,
      "action_type": "StayStill",
      "movement_state": "StayStill",
      "dialog_text": "Jason, winning the game is great, but imagine how proud the whole school will be if we lead the way in sustainability too. The environmental club meeting is our chance to make that happen.",
      "plan": "Jason seems distracted by the game, but I need to bring the focus back to the environmental meeting. I should appeal to his sense of teamwork and school pride.",
      "target_location": null
    },
    {
      "time": 22.5411072,
      "action_type": "MoveToHideSpot",
      "movement_state": "Walk",
      "dialog_text": "Everyone, let's hide behind the cafe bar counter now! It's our best chance to stay safe.",
      "plan": "There is an active shooter nearby, and Ethan and Jason are urging us to hide. I need to act quickly to stay safe. Hiding behind the cafe bar counter seems like a good spot.",
      "target_location": {
        "x": -0.910903931,
        "y": 0.0,
        "z": -39.79232
      }
    }
  ],
  "memories": [
    {
      "time": 4.436374,
      "description": "Asked Ethan, Jason, and Frank if they are attending the environmental club meeting to encourage participation and support for recycling initiatives."
    },
    {
      "time": 13.7300444,
      "description": "Encouraged Jason to see the environmental club meeting as an opportunity to bring pride to the school alongside the sports team."
    },
    {
      "time": 22.5411072,
      "description": "Heard gunshot and realized there is an active shooter nearby. Responded to Ethan and Jason's call to hide by sprinting to hide behind the cafe bar counter for safety."
    }
  ],
