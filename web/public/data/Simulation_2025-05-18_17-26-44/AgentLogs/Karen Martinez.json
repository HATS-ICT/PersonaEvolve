  "actions": [
    {
      "time": 3.17110562,
      "action_type": "StayStill",
      "movement_state": "StayStill",
      "dialog_text": "¡Buenos días, clase! Let's have a wonderful day learning about Spanish and Hispanic culture.",
      "plan": "Estoy lista para comenzar la clase y compartir un poco de la cultura hispana con mis estudiantes. Quiero que se sientan motivados y curiosos hoy.",
      "target_location": null
    },
    {
      "time": 10.7091351,
      "action_type": "StayStill",
      "movement_state": "StayStill",
      "dialog_text": "Vamos a empezar con una pequeña actividad cultural. ¿Quién quiere compartir algo que sabe sobre la cultura hispana?",
      "plan": "Ahora es un buen momento para introducir una actividad cultural que motive a los estudiantes a participar activamente.",
      "target_location": null
    },
    {
      "time": 18.93769,
